# ─── Required for production ───────────────────────────────────────────────
# Public site URL (used for SEO, Open Graph, sitemap)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Session signing + file encryption (use: openssl rand -hex 32)
AUTH_SECRET=

# Optional separate secret for file encryption (recommended in production)
FILE_ENCRYPTION_SECRET=

# PostgreSQL — Neon, Supabase, or Railway (free tiers available)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# S3-compatible object storage — Cloudflare R2, AWS S3, or Supabase Storage
S3_BUCKET=click-compress-files
S3_REGION=auto
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Required for Cloudflare R2 / Supabase / MinIO (leave empty for AWS S3)
S3_ENDPOINT=

# ─── Optional: Smart AI routing ──────────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen-2.5-7b-instruct:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ─── Compression worker (GCP e2-micro, always on) ────────────────────────
# Browser uploads PDF/video directly here (bypasses Vercel 4.5 MB limit).
# Setup: docs/GCP-COMPRESSION-WORKER.md
NEXT_PUBLIC_COMPRESSION_WORKER_URL=https://compression.clickcompress.com

# Worker-side only (set in docker-compose on the VM, not in Vercel):
# WORKER_MAX_UPLOAD_MB=100
# WORKER_ALLOWED_ORIGINS=https://clickcompress.com,https://www.clickcompress.com
# WORKER_SECRET=   # optional; do not use with browser-direct uploads

# ─── Local development (no DATABASE_URL) ─────────────────────────────────
# Without DATABASE_URL, users and files are stored in .data/ on disk.
