# ─── Required for production ───────────────────────────────────────────────
# Public site URL (used for SEO, Open Graph, sitemap)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Session signing + file encryption (use: openssl rand -hex 32)
AUTH_SECRET=

# Optional separate secret for file encryption (recommended in production)
FILE_ENCRYPTION_SECRET=

# PostgreSQL — Neon, Supabase, or Railway (free tiers available)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# S3-compatible object storage — Cloudflare R2, AWS S3, or Supabase Storage
S3_BUCKET=click-compress-files
S3_REGION=auto
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Required for Cloudflare R2 / Supabase / MinIO (leave empty for AWS S3)
S3_ENDPOINT=

# ─── Optional: Smart AI routing ──────────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen-2.5-7b-instruct:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ─── Local development (no DATABASE_URL) ─────────────────────────────────
# Without DATABASE_URL, users and files are stored in .data/ on disk.
